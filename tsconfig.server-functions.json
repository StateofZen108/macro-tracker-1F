{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "api/**/*.ts",
    "server/**/*.ts",
    "src/domain/accountState.ts",
    "src/domain/supportBundle.ts",
    "src/domain/foodCatalog/**/*.ts",
    "src/utils/openFoodFacts.ts",
    "src/utils/labelOcrPayload.ts",
    "src/types.ts"
  ]
}
