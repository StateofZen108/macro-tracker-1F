{
  "name": "macro-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:ocr": "vercel dev --yes --listen 3000",
    "dev:ocr:start": "powershell -ExecutionPolicy Bypass -File scripts/ocr-dev-up.ps1 -SkipHealthCheck",
    "dev:ocr:ready": "powershell -ExecutionPolicy Bypass -File scripts/ocr-dev-up.ps1",
    "dev:ocr:stop": "powershell -ExecutionPolicy Bypass -File scripts/ocr-dev-down.ps1",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview --host",
    "preview:restore-test": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "health:ocr": "powershell -ExecutionPolicy Bypass -File scripts/ocr-healthcheck.ps1",
    "test:bundle": "node scripts/check-chunk-budgets.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coach-wave1:unit": "vitest run tests/unit/coaching.wave1.replay.spec.ts tests/unit/coaching.wave1.settings-sync.spec.ts tests/unit/coaching.engine.history.spec.ts tests/unit/checkIns.math.spec.ts tests/integration/storage.importExport.spec.ts",
    "test:food-truth:unit": "vitest run tests/unit/featureFlags.spec.ts tests/unit/foodCatalog.importQuality.spec.ts tests/unit/foodCatalog.identity.spec.ts tests/unit/foodCatalog.describe.spec.ts tests/unit/foodCatalog.ranking.spec.ts tests/unit/foodCatalog.barcodeResolution.spec.ts tests/unit/addFoodPane.helpers.spec.ts tests/unit/labelOcr.normalize.spec.ts tests/unit/labelOcr.nutrients.spec.ts tests/unit/labelOcr.reviewSession.spec.ts tests/unit/labelOcr.servingBasis.spec.ts tests/unit/labelOcr.payload.spec.ts tests/unit/nutritionLabelOcr.contract.spec.ts tests/unit/diagnostics.spec.ts",
    "test:food-truth:integration": "vitest run tests/integration/catalogCache.storage.spec.ts tests/integration/foodCatalog.cache.spec.ts tests/integration/storage.importExport.spec.ts tests/integration/foodCatalog.providers.spec.ts tests/integration/foodCatalog.server.spec.ts tests/integration/labelOcr.api.spec.ts tests/integration/labelOcr.extract.spec.ts tests/integration/labelOcr.storage.spec.ts tests/integration/ocrReview.spec.ts tests/integration/foodForm.ocrReview.spec.ts",
    "test:food-truth:preview": "vitest run tests/integration/foodForm.ocrReview.spec.ts tests/integration/ocrReview.spec.ts tests/unit/addFoodPane.helpers.spec.ts",
    "test:food-truth:benchmark": "node scripts/food-truth-benchmark.mjs",
    "test:food-truth:benchmark-guard": "node scripts/food-truth-benchmark-guard.mjs",
    "test:food-truth:update-benchmark": "node scripts/food-truth-update-benchmark.mjs",
    "test:food-truth:wave1-launch": "node scripts/food-truth-wave1-launch-gate.mjs",
    "test:food-truth:promote-synthetic-corpus": "node scripts/food-truth-promote-synthetic-corpus.mjs",
    "test:food-truth:capture-real-corpus": "node scripts/food-truth-capture-real-corpus.mjs",
    "test:food-truth:wave1-acceptance": "node scripts/food-truth-record-wave1-acceptance.mjs",
    "test:food-truth:wave1-acceptance:auto": "node scripts/food-truth-record-engineering-acceptance.mjs",
    "test:food-truth:engineering-ready": "node scripts/food-truth-engineering-gate.mjs",
    "test:e2e:generic": "playwright test",
    "test:e2e": "npm run test:e2e:generic",
    "test:e2e:qa-dev-smoke": "playwright test --config=playwright.qa-dev-smoke.config.ts",
    "test:e2e:qa-generic-preview": "playwright test --config=playwright.generic-preview.config.ts",
    "test:e2e:lane-guard": "node scripts/e2e-lane-guard.mjs",
    "test:e2e:coach-preview": "playwright test --config=playwright.coach-wave1.config.ts",
    "test:e2e:personal-library-preview": "playwright test --config=playwright.personal-library.config.ts",
    "test:coach-wave1:mobile": "npm run test:e2e:coach-preview",
    "test:coach-wave1": "npm run test:coach-wave1:unit && npm run test:coach-wave1:mobile",
    "test:coach-wave1:update-baseline": "node scripts/run-coach-baseline-update.mjs",
    "test:coach-wave1:personal-shadow": "node scripts/run-coach-wave1-personal-shadow.mjs",
    "test:coach-baseline-guard": "node scripts/coach-baseline-guard.mjs",
    "test:personal-library:mobile": "npm run test:e2e:personal-library-preview",
    "test:psmf-phase:unit": "vitest run tests/unit/coaching.psmf-garmin.unit.spec.ts tests/unit/coaching.psmf-garmin.replay.spec.ts",
    "test:psmf-phase:storage": "vitest run tests/unit/sync.psmfRecovery.spec.ts tests/integration/storage.psmfRecovery.spec.ts",
    "test:psmf-phase:preview": "playwright test --config=playwright.psmf-phase.config.ts",
    "test:psmf-phase:replay": "vitest run tests/unit/coaching.psmf-garmin.replay.spec.ts",
    "test:psmf-phase:update-baseline": "node scripts/run-psmf-phase-baseline-update.mjs",
    "test:psmf-phase:baseline-guard": "node scripts/psmf-phase-baseline-guard.mjs",
    "test:psmf-phase": "npm run test:psmf-phase:unit && npm run test:psmf-phase:storage && npm run test:psmf-phase:replay && npm run test:psmf-phase:baseline-guard && npm run test:psmf-phase:preview",
    "test:recovery-layer:unit": "vitest run tests/unit/sync.psmfRecovery.spec.ts tests/integration/storage.psmfRecovery.spec.ts",
    "test:recovery-layer:preview": "playwright test --config=playwright.recovery-layer.config.ts",
    "test:recovery-layer:replay": "vitest run tests/unit/sync.psmfRecovery.spec.ts",
    "test:recovery-layer:update-baseline": "node scripts/run-recovery-layer-baseline-update.mjs",
    "test:recovery-layer:baseline-guard": "node scripts/recovery-layer-baseline-guard.mjs",
    "test:recovery-layer": "npm run test:recovery-layer:unit && npm run test:recovery-layer:replay && npm run test:recovery-layer:baseline-guard && npm run test:recovery-layer:preview",
    "test:garmin-connect:unit": "vitest run tests/unit/garmin.crypto.spec.ts tests/unit/garmin.service.spec.ts tests/integration/garmin.routes.spec.ts",
    "test:garmin-connect:preview": "playwright test --config=playwright.garmin-connect.config.ts",
    "test:garmin-connect": "npm run test:garmin-connect:unit && npm run test:garmin-connect:preview",
    "test:psmf-garmin:unit": "vitest run tests/unit/coaching.psmf-garmin.unit.spec.ts tests/unit/coaching.psmf-garmin.replay.spec.ts tests/unit/sync.psmfRecovery.spec.ts tests/integration/storage.psmfRecovery.spec.ts tests/unit/garmin.crypto.spec.ts tests/unit/garmin.service.spec.ts tests/integration/garmin.routes.spec.ts",
    "test:psmf-garmin:preview": "playwright test --config=playwright.psmf-garmin.config.ts",
    "test:psmf-garmin:replay": "vitest run tests/unit/coaching.psmf-garmin.replay.spec.ts",
    "test:psmf-garmin:update-baseline": "node scripts/run-psmf-garmin-baseline-update.mjs",
    "test:psmf-garmin:baseline-guard": "node scripts/psmf-garmin-baseline-guard.mjs",
    "test:psmf-garmin": "npm run test:psmf-garmin:unit && npm run test:psmf-garmin:replay && npm run test:psmf-garmin:baseline-guard && npm run test:psmf-garmin:preview",
    "test:phase-planner:unit": "vitest run tests/unit/dietPhases.editor.spec.ts tests/unit/sync.psmfRecovery.spec.ts tests/integration/storage.psmfRecovery.spec.ts",
    "test:phase-planner:preview": "npm run test:psmf-phase:preview && npm run test:psmf-garmin:preview",
    "test:all": "npm run lint && npm run build && npm run test:bundle && npm run test:unit && npm run test:e2e",
    "test:release": "npm run test:all && npm run test:e2e:lane-guard && npm run test:e2e:personal-library-preview && npm run test:e2e:coach-preview",
    "test:release:psmf-garmin": "npm run test:release && npm run test:psmf-garmin",
    "test:psmf-garmin:release-confidence": "npm run test:release && npm run test:psmf-garmin",
    "test:qa:unit": "vitest run tests/unit/qaReleaseGate.spec.ts tests/integration/qaReleaseGate.spec.ts",
    "test:qa:release-gate": "node scripts/qa-release-gate.mjs"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@supabase/supabase-js": "^2.103.0",
    "@zxing/browser": "^0.1.5",
    "fake-indexeddb": "^6.2.4",
    "heic2any": "^0.0.4",
    "idb": "^7.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.4",
    "globals": "^17.4.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.1.0",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "@rollup/plugin-terser": "1.0.0",
    "serialize-javascript": "7.0.3"
  }
}
