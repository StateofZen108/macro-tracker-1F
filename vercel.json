{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "if [ \"$VERCEL_ENV\" = \"preview\" ]; then VITE_APP_FEATURE_PRESET=paid-cut-os-preview npm run build; else npm run build; fi",
  "functions": {
    "api/sync/bootstrap.ts": {
      "maxDuration": 30
    },
    "api/sync/bootstrap/status.ts": {
      "maxDuration": 15
    },
    "api/label-ocr/extract.ts": {
      "maxDuration": 60
    },
    "api/sync/pull.ts": {
      "maxDuration": 30
    },
    "api/sync/push.ts": {
      "maxDuration": 30
    },
    "api/garmin/[action].ts": {
      "maxDuration": 60
    }
  }
}
